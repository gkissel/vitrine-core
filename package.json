{
	"name": "my-turborepo",
	"private": true,
	"scripts": {
		"build": "turbo run build",
		"build:front-end": "turbo run build --filter=@repo/storefront",
		"build:medusa": "turbo run build --filter=@repo/backend",
		"dev": "turbo run dev",
		"dev:front-end": "turbo run dev --filter=@repo/storefront",
		"dev:medusa": "turbo run dev --filter=@repo/backend",
		"lint": "turbo run lint",
		"format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md,css}\"",
		"check-types": "turbo run check-types",
		"db:migrate": "pnpm --filter @repo/backend run db:migrate"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.14",
		"prettier": "^3.8.3",
		"turbo": "^2.9.8",
		"typescript": "6.0.3"
	},
	"packageManager": "pnpm@10.28.2",
	"pnpm": {
		"packageExtensions": {
			"@medusajs/medusa": {
				"dependencies": {
					"zod": "3.25.76"
				}
			}
		}
	},
	"engines": {
		"node": ">=20"
	}
}
