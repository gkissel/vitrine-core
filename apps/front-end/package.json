{
  "name": "@repo/storefront",
  "private": true,
  "scripts": {
    "predev": "node ../../scripts/check-local-envs.mjs --scope=storefront",
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf .next node_modules",
    "prettier": "prettier --write --ignore-unknown .",
    "prettier:check": "prettier --check --ignore-unknown .",
    "lint": "prettier --check --ignore-unknown .",
    "format": "prettier --write --ignore-unknown .",
    "test": "pnpm run test:unit",
    "test:all": "pnpm run prettier:check && pnpm run test:unit",
    "test:unit": "vitest run --passWithNoTests",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/e2e/smoke --project=chromium",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.10",
    "@heroicons/react": "^2.2.0",
    "@medusajs/js-sdk": "^2.14.2",
    "@repo/site-config": "workspace:*",
    "@sentry/nextjs": "^10.51.0",
    "@sentry/profiling-node": "^10.51.0",
    "@stripe/react-stripe-js": "^6.3.0",
    "@stripe/stripe-js": "^9.4.0",
    "clsx": "^2.1.1",
    "geist": "^1.7.0",
    "next": "16.2.4",
    "nuqs": "^2.8.9",
    "posthog-js": "^1.372.8",
    "posthog-node": "^5.33.2",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-instantsearch": "^7.31.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@medusajs/types": "^2.14.2",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "happy-dom": "^20.9.0",
    "postcss": "^8.5.14",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "schema-dts": "^2.0.0",
    "tailwindcss": "^4.2.4",
    "typescript": "5.9.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
