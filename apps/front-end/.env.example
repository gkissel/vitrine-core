# =============================================================================
# Storefront Environment Variables
# =============================================================================
# Copy to .env.local for local development:  cp .env.example .env.local
# For production, set these in Vercel project settings.
# =============================================================================

# --- Backend Connection -------------------------------------------------------
# Medusa backend API URL.
# Local:       http://localhost:9000
# Production:  https://api.example.com
MEDUSA_BACKEND_URL=http://localhost:9000

# Required. Publishable API key from Medusa.
# Run the seed script, then copy from output, admin UI, or:
#   psql medusa_db -c "SELECT token FROM api_key WHERE type = 'publishable' LIMIT 1;"
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=

# --- Region -------------------------------------------------------------------
# Optional. Skip automatic region detection and use a specific region.
# Useful when you only have one region. If Meilisearch indexing is enabled,
# backend MEILISEARCH_REGION_ID should match this region.
NEXT_PUBLIC_DEFAULT_REGION_ID=

# --- Stripe -------------------------------------------------------------------
# Optional. Publishable key for the Stripe checkout form.
# Get from: https://dashboard.stripe.com/test/apikeys
NEXT_PUBLIC_STRIPE_KEY=

# --- Site Metadata ------------------------------------------------------------
# Used in browser tab titles, OG images, and footer copyright.
# Preferred public storefront URL for canonical metadata, sitemap, robots,
# and JSON-LD absolute URLs. Falls back to Vercel's production URL automatically.
NEXT_PUBLIC_SITE_URL=
#
# Optional. Public logo URL for Organization JSON-LD on the homepage.
# Use an absolute URL or a site-relative path (e.g. /logo.png).
NEXT_PUBLIC_SITE_LOGO_URL=
#
# Optional. Legal company name for Organization JSON-LD.
SITE_COMPANY_LEGAL_NAME=
#
# Optional. Customer support phone number for Organization JSON-LD.
SITE_COMPANY_PHONE=
#
# Optional. Customer support email for Organization JSON-LD.
SITE_COMPANY_EMAIL=
#
# Optional. Comma-separated social/profile URLs for Organization JSON-LD.
SITE_COMPANY_SAME_AS=
SITE_NAME="Your Store Name"
COMPANY_NAME="Your Company"

# --- E2E Testing --------------------------------------------------------------
# Enables cookie-backed order fixtures used by Playwright order-detail tests.
# Playwright sets this automatically via storefront/playwright.config.ts.
# E2E_ORDER_FIXTURES=1
# Optional. Override the base URL when pointing Playwright at an existing app.
PLAYWRIGHT_BASE_URL=
# Optional. Override the command Playwright uses to boot the local stack.
PLAYWRIGHT_WEB_SERVER_COMMAND=
# Optional. Override the local psql binary path used by some E2E fixtures.
PSQL_PATH=
# Optional. Real-account credentials for the order lifecycle E2E spec.
E2E_REAL_ACCOUNT_EMAIL=
E2E_REAL_ACCOUNT_PASSWORD=
# Optional. Admin credentials for E2E flows that require admin-side setup.
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=

# --- Cache Revalidation -------------------------------------------------------
# Secret token for on-demand cache revalidation via /api/revalidate.
# Generate with: openssl rand -hex 32
REVALIDATE_SECRET=

# --- S3 / Cloudflare R2 (image optimization) ----------------------------------
# Hostname for the R2 public bucket, used in next/image remotePatterns.
# Without this, product/review images from R2 won't be optimized by Next.js.
S3_IMAGE_HOSTNAME=

# --- Cart Recovery ------------------------------------------------------------
# HMAC secret for verifying abandoned cart recovery links.
# Must match CART_RECOVERY_SECRET in the backend.
# Generate with: openssl rand -hex 32
CART_RECOVERY_SECRET=

# --- Sentry -------------------------------------------------------------------
# Sentry — Error monitoring, performance tracing, session replay
# Create a project at sentry.io, select Next.js, copy the DSN
# DSN is safe to expose client-side (public by design, rate limiting is server-side)
NEXT_PUBLIC_SENTRY_DSN=
# Trace sample rate (0.0 to 1.0). Default 0.2 (20%). Set to 1.0 for local dev.
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=
# Server-side trace sample rate (defaults to 0.2 if not set)
SENTRY_TRACES_SAMPLE_RATE=
# Source map uploads (build-time only) — generate token at sentry.io/settings/auth-tokens/
# These can also go in .env.sentry-build-plugin (gitignored) instead
SENTRY_AUTH_TOKEN=
# Exact Sentry organization slug for this storefront project. Do not paste with trailing whitespace/newlines.
SENTRY_ORG=
# Exact Sentry project slug for this storefront project. Do not paste with trailing whitespace/newlines.
SENTRY_PROJECT=
# Sentry environment tag. Set per-environment in Vercel dashboard
# (production → "production", preview → "preview"). Defaults to NODE_ENV locally.
NEXT_PUBLIC_SENTRY_ENVIRONMENT=

# --- Social Media Links -------------------------------------------------------
# Optional. Only links with values will show icons in the footer.
SOCIAL_FACEBOOK=
SOCIAL_INSTAGRAM=
SOCIAL_TWITTER=
SOCIAL_GITHUB=
SOCIAL_YOUTUBE=
SOCIAL_TIKTOK=
SOCIAL_LINKEDIN=
SOCIAL_PINTEREST=

# --- PostHog ------------------------------------------------------------------
# PostHog — Product analytics, web analytics, session replay, feature flags
# Create a project at posthog.com, copy the Project API Key
# POSTHOG_API_KEY is server-only; NEXT_PUBLIC_ vars are exposed to the browser
# Optional. Defaults to true. Set to false to disable the consent banner and
# consent-gated PostHog startup. Attribution persistence and normal analytics
# remain active either way.
NEXT_PUBLIC_CONSENT_FOUNDATION_ENABLED=true
POSTHOG_API_KEY=
NEXT_PUBLIC_POSTHOG_KEY=
# Optional. Defaults to https://us.i.posthog.com (US region)
NEXT_PUBLIC_POSTHOG_HOST=
# Optional. Secure API key for local feature flag evaluation (avoids network calls)
# Generate at PostHog > Settings > Feature Flags Secure Keys
POSTHOG_PERSONAL_API_KEY=

# --- Meilisearch ---------------------------------------------------------------
# Full-text search with faceted filtering. When set, storefront queries
# Meilisearch directly from the browser instead of Medusa REST.
# Use a search-only API key here (never the master key).
# See docs/features/search.md for setup and customization guide.
NEXT_PUBLIC_MEILISEARCH_HOST=
NEXT_PUBLIC_MEILISEARCH_API_KEY=
NEXT_PUBLIC_MEILISEARCH_INDEX_NAME=products
# Optional. Local-only comparison value used to warn if the public search key
# accidentally matches the backend master key. Do not expose this in production.
MEILISEARCH_API_KEY=
