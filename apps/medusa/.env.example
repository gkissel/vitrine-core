# =============================================================================
# Backend Environment Variables
# =============================================================================
# Copy to .env for local development:  cp .env.example .env
# For production, set these in your hosting provider (e.g. Railway dashboard).
# =============================================================================

# --- Database -----------------------------------------------------------------
# Required. PostgreSQL connection string.
# Local:      postgres://localhost/medusa_db
# Railway:    Auto-provisioned by PostgreSQL plugin
DATABASE_URL=postgres://localhost/medusa_db

# --- Redis --------------------------------------------------------------------
# Optional locally (in-memory fallback). Required in production.
# When set, enables: caching-redis, event-bus-redis, workflow-engine-redis, locking-redis.
# Local:      redis://localhost:6379
# Railway:    Auto-provisioned by Redis plugin
REDIS_URL=

# --- Security -----------------------------------------------------------------
# Auth token signing.
# Production: generate with `openssl rand -hex 32`
# medusa-config.ts will throw if these are insecure in production.
JWT_SECRET=replace-with-long-random-secret
COOKIE_SECRET=replace-with-long-random-secret

# --- CORS ---------------------------------------------------------------------
# Comma-separated origins (protocol + host + port, no trailing slash).
# Must include every origin that makes requests to the backend.
STORE_CORS=http://localhost:3000
ADMIN_CORS=http://localhost:5173,http://localhost:9000
AUTH_CORS=http://localhost:5173,http://localhost:9000

# --- Stripe -------------------------------------------------------------------
# Optional. When STRIPE_API_KEY is set, the Stripe payment module loads.
# Get keys from: https://dashboard.stripe.com/test/apikeys
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
# Note: STRIPE_WEBHOOK_SECRET is required in production when Stripe is enabled.

# --- Resend (email notifications) ---------------------------------------------
# Optional. When RESEND_API_KEY is set, the Resend notification module loads.
# Get key from: https://resend.com/api-keys
RESEND_API_KEY=
# Optional. Audience ID for syncing newsletter subscribers into Resend Contacts.
# If left blank, newsletter audience sync workflows skip gracefully.
RESEND_AUDIENCE_ID=
RESEND_FROM_EMAIL=noreply@crowcommerce.org

# --- S3 / Cloudflare R2 (file storage) ----------------------------------------
# Optional. When S3_BUCKET is set, the S3 file provider loads for persistent storage.
# Without this, files are stored in memory and lost on every backend restart.
# Create a bucket and API token at: https://developers.cloudflare.com/r2/
S3_FILE_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_REGION=auto
S3_ENDPOINT=

# --- Storefront URL -----------------------------------------------------------
# Used in email templates for links (order confirmation, password reset, etc.).
# Set to your production storefront domain in production.
STOREFRONT_URL=http://localhost:3000
# Optional. Shared secret for storefront /api/revalidate. When set alongside STOREFRONT_URL,
# Medusa subscribers automatically invalidate storefront catalog caches after
# product and collection changes.
# Generate with: openssl rand -hex 32
REVALIDATE_SECRET=

# --- Admin --------------------------------------------------------------------
# Public backend URL for the admin UI build. Only needed in production.
MEDUSA_BACKEND_URL=

# --- Admin Order Alerts -------------------------------------------------------
# Comma-separated email addresses to receive new order notifications.
# Requires Resend to be configured. Leave empty to disable.
ADMIN_ORDER_EMAILS=

# --- Cart Recovery ------------------------------------------------------------
# HMAC secret for abandoned cart recovery tokens.
# Must match CART_RECOVERY_SECRET in the storefront.
# Generate with: openssl rand -hex 32
CART_RECOVERY_SECRET=

# --- Sentry -------------------------------------------------------------------
# Sentry — Error monitoring and performance tracing
# Create a project at sentry.io, select Node.js, copy the DSN
SENTRY_DSN=
# Trace sample rate (0.0 to 1.0). Default 0.2 (20%). Set to 1.0 for local dev.
SENTRY_TRACES_SAMPLE_RATE=
# Sentry environment tag. Set in Railway per-environment. Defaults to NODE_ENV locally.
SENTRY_ENVIRONMENT=

# --- PostHog ------------------------------------------------------------------
# PostHog — Backend analytics/events module for Medusa.
# Create a project at posthog.com and copy the Project API Key for server-side events.
# Leave blank to disable backend analytics gracefully.
POSTHOG_EVENTS_API_KEY=
# Optional. Defaults to https://us.i.posthog.com if left blank.
POSTHOG_HOST=

# --- Meilisearch ---------------------------------------------------------------
# Full-text search with faceted filtering. Optional — storefront falls back to
# Medusa REST search when not configured. See docs/features/search.md.
# Local: brew install meilisearch && meilisearch --master-key="your-master-key"
# Production: use Meilisearch Cloud (meilisearch.com/cloud) or self-host
# After starting backend, trigger initial sync: POST /admin/meilisearch/sync
MEILISEARCH_HOST=
MEILISEARCH_API_KEY=
# Required for accurate calculated-price indexing. Match your storefront region.
MEILISEARCH_REGION_ID=
MEILISEARCH_PRODUCT_INDEX_NAME=products

# --- Test Tooling -------------------------------------------------------------
# Local/backend test selection. Usually set by npm scripts rather than manually.
# Valid values: unit, integration:http, integration:modules
TEST_TYPE=
