{
	"$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
	"root": false,
	"extends": ["@repo/biome-config/base", "@repo/biome-config/next-js"],

	"overrides": [
		{
			"includes": ["src/components/ui/**"],
			"linter": {
				"rules": {
					"suspicious": {
						"noArrayIndexKey": "off"
					}
				}
			}
		},
		{
			"includes": ["src/htpp/**"],
			"linter": {
				"rules": {
					"suspicious": {
						"noExplicitAny": "off"
					}
				}
			}
		}
	]
}
