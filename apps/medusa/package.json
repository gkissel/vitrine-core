{
	"name": "@repo/backend",
	"version": "0.0.1",
	"description": "A starter for Medusa projects.",
	"author": "Medusa (https://medusajs.com)",
	"license": "MIT",
	"keywords": [
		"sqlite",
		"postgres",
		"typescript",
		"ecommerce",
		"headless",
		"medusa"
	],
	"scripts": {
		"build": "medusa build",
		"seed": "medusa exec ./src/scripts/seed.ts &&  medusa user -e admin@admin.com -p admin123",
		"start": "medusa start",
		"db:migrate": "medusa db:migrate",
		"predev": "node ../../scripts/check-local-envs.mjs --scope=backend",
		"dev": "medusa develop",
		"test:integration:http": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
		"test:integration:modules": "TEST_TYPE=integration:modules NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
		"test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit --passWithNoTests",
		"typecheck": "tsc --noEmit",
		"check-types": "tsc --noEmit",
		"lint": "prettier --check --ignore-unknown .",
		"format": "prettier --write --ignore-unknown .",
		"prettier": "prettier --write --ignore-unknown .",
		"prettier:check": "prettier --check --ignore-unknown .",
		"clean": "rm -rf .medusa node_modules"
	},
	"dependencies": {
		"@medusajs/admin-sdk": "2.13.1",
		"@medusajs/admin-shared": "2.13.1",
		"@medusajs/analytics-posthog": "2.13.1",
		"@medusajs/caching-redis": "^2.13.1",
		"@medusajs/cli": "2.13.1",
		"@medusajs/core-flows": "2.13.1",
		"@medusajs/dashboard": "2.13.1",
		"@medusajs/draft-order": "2.13.1",
		"@medusajs/framework": "2.13.1",
		"@medusajs/icons": "^2.15.5",
		"@medusajs/medusa": "2.13.1",
		"@medusajs/types": "2.13.1",
		"@medusajs/ui": "^4.1.15",
		"@react-pdf/renderer": "^4.5.1",
		"@sentry/node": "^10.51.0",
		"@sentry/profiling-node": "^10.51.0",
		"express": "^5.1.0",
		"ioredis": "^5.10.1",
		"jsonwebtoken": "^9.0.3",
		"meilisearch": "^0.58.0",
		"multer": "^2.1.1"
	},
	"devDependencies": {
		"@medusajs/test-utils": "2.13.1",
		"@swc/core": "^1.15.33",
		"@swc/jest": "^0.2.39",
		"@types/express": "^5.0.3",
		"@types/jest": "^30.0.0",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/multer": "^2.1.0",
		"@types/node": "^25.6.0",
		"@types/react": "^18.3.2",
		"@types/react-dom": "^18.2.25",
		"jest": "^30.3.0",
		"prettier": "3.8.3",
		"prop-types": "^15.8.1",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"ts-node": "^10.9.2",
		"typescript": "^5.9.3",
		"vite": "^5.4.21",
		"yalc": "1.0.0-pre.53"
	},
	"engines": {
		"node": ">=20"
	}
}
